# ============================================================
#  CloudDrive configuration
#  Copy this file to ".env" and adjust values.
# ============================================================

# --- Security ---
# Used to sign JWT auth tokens AND local pre-signed download links.
# Generate a real one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- Database ---
# Local dev (default): SQLite file.
# Production (AWS RDS): postgresql+psycopg2://USER:PASS@HOST:5432/clouddrive
DATABASE_URL=sqlite:///./clouddrive.db

# --- Storage backend ---
# "local"  -> stores files on disk, fakes pre-signed URLs (great for demos, no AWS needed)
# "s3"     -> stores files in AWS S3 using real pre-signed URLs
STORAGE_BACKEND=local

# Where "local" backend keeps files
LOCAL_STORAGE_DIR=./storage_data

# --- AWS S3 (only needed when STORAGE_BACKEND=s3) ---
AWS_REGION=us-east-1
S3_BUCKET=my-clouddrive-bucket
# Credentials are read from the standard AWS chain (env vars, ~/.aws, or ECS task role).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- App ---
# Per-user storage quota in megabytes
DEFAULT_QUOTA_MB=200
# Public base URL the browser uses to reach this API (for local pre-signed links)
PUBLIC_API_URL=http://localhost:8000
